# PilotCode Configuration
# Copy this to .env and fill in your values

# Auth token (leave empty to auto-generate on first run)
# PILOTCODE_TOKEN=

# Default working directory for new sessions
# PILOTCODE_CWD=/Users/you/Dev

# Server port (default: 3456)
# PILOTCODE_PORT=3456

# Cloudflare Tunnel name (default: pilotcode)
# CLOUDFLARE_TUNNEL=pilotcode

# DuckDNS (optional — only if using DuckDNS for dynamic DNS)
# DUCKDNS_DOMAIN=yourdomain
# DUCKDNS_TOKEN=your-duckdns-token-here
