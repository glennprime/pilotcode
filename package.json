{
  "name": "pilotcode",
  "version": "1.0.0",
  "description": "Self-hosted web UI for Claude Code — control from your phone",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "tunnel": "cloudflared tunnel --url http://localhost:3456"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
